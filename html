<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>moontv → kvideo 转换器</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            max-width: 900px;
            margin: 20px auto;
            padding: 0 20px;
        }
        textarea {
            width: 100%;
            height: 200px;
            font-family: monospace;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #ddd;
            border-radius: 4px;
        }
        button {
            padding: 10px 20px;
            background: #007aff;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
        }
        button:hover {
            background: #0056b3;
        }
        .output {
            background: #f8f9fa;
        }
    </style>
</head>
<body>
    <h2>moontv → kvideo 配置转换器</h2>
    <p>1. 在下方粘贴你的 moontv JSON 配置：</p>
    <textarea id="input" placeholder='粘贴 moontv JSON，例如：
{
  "cache_time": 7200,
  "api_site": {
    "dytczy": {
      "api": "http://xxx.com/api.php/provide/vod",
      "name": "示例资源",
      "detail": "http://xxx.com"
    }
  }
}'></textarea>

    <button onclick="convert()">转换为 kvideo 格式</button>

    <p>2. 转换后的 kvideo JSON（可直接复制使用）：</p>
    <textarea id="output" class="output" readonly placeholder="转换结果将显示在这里..."></textarea>

    <script>
        function convert() {
            const input = document.getElementById('input');
            const output = document.getElementById('output');
            const raw = input.value.trim();

            if (!raw) {
                output.value = '⚠️ 请先粘贴 moontv JSON 配置';
                return;
            }

            try {
                const moontv = JSON.parse(raw);

                if (!moontv.api_site || typeof moontv.api_site !== 'object') {
                    output.value = '❌ 格式错误：未找到 api_site 字段或格式不对';
                    return;
                }

                const kvideo = Object.entries(moontv.api_site).map(([key, site]) => ({
                    id: key,
                    name: site.name,
                    baseUrl: site.api,
                    group: "normal",
                    enabled: true,
                    priority: 1
                }));

                output.value = JSON.stringify(kvideo, null, 2);
            } catch (e) {
                output.value = `❌ JSON 解析失败：\n${e.message}\n\n请检查你的输入格式是否正确。`;
            }
        }
    </script>
</body>
</html>
